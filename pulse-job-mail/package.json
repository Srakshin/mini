{
  "name": "pulse-job-mail",
  "version": "1.0.0",
  "description": "Production-ready job alert & news aggregation platform with Gmail integration, AI-powered smart summaries, job crawling, and multi-email delivery. Built with TypeScript, Node.js, MongoDB, and Google Gemini AI.",
  "author": "Srakshin",
  "keywords": [
    "job-alerts",
    "gmail-integration",
    "email-aggregation",
    "job-crawling",
    "ai-summaries",
    "nodejs-backend",
    "typescript",
    "mongodb",
    "express-api",
    "google-oauth",
    "nodemailer",
    "cron-jobs",
    "jwt-authentication",
    "smart-notifications",
    "news-aggregation"
  ],
  "license": "MIT",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node backend/src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.11.0",
    "bcryptjs": "^3.0.2",
    "cheerio": "^1.1.2",
    "colors": "^1.4.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.0.1",
    "googleapis": "^154.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.16.5",
    "morgan": "^1.10.1",
    "nanoid": "^5.1.5",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.5",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
